# ── 資料庫（Phase 2 使用）────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://quant_user:quant_password@localhost:5432/quant_platform

# ── Binance Futures API ───────────────────────────────────────
# 公開端點（K 線 / 合約清單）不需要金鑰
# 若需要下單或取得帳戶資訊才填入
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── 伺服器設定 ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
